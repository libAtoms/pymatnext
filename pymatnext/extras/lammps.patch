+------------------------------------------------------------------------- */
+
+// #define SWAP_POS
+
+#ifdef DEBUG
+#include <iostream>
+#endif
+
+#include <stdio.h>
+#include <string.h>
+#include "fix_ns_type.h"
+#include "atom.h"
+#include "comm.h"
+#include "force.h"
+#include "pair.h"
+#include "modify.h"
+#include "neighbor.h"
+#include "compute.h"
+#include "update.h"
+#include "random_mars.h"
+#include "domain.h"
+#include "memory.h"
+#include "respa.h"
